
```python
import pandas as pd
import numpy as np
from pathlib import Path

# Constants
YEAR = 2026
MATCH_CSV = Path(f"frc_matches_{YEAR}.csv")
OPR_CSV = Path(f"frc_matches_{YEAR}_match_opr.csv")
EPA_CSV = Path(f"frc_matches_{YEAR}_match_epa.csv")
OUTPUT_BEFORE = Path(f"frc_matches_{YEAR}_opr+EPA_before.csv")
OUTPUT_AFTER = Path(f"frc_matches_{YEAR}_opr+EPA_after.csv")

# Check if input files exist
if not MATCH_CSV.exists():
    raise FileNotFoundError(f"Missing match CSV: {MATCH_CSV}")
if not OPR_CSV.exists():
    raise FileNotFoundError(f"Missing OPR CSV: {OPR_CSV}")
if not EPA_CSV.exists():
    raise FileNotFoundError(f"Missing EPA CSV: {EPA_CSV}")

# Load match data
match_df = pd.read_csv(
    MATCH_CSV,
    usecols=["key", "winning_alliance", "alliances", "score_breakdown"],
    low_memory=False,
)
match_df = match_df[match_df["winning_alliance"].isin(["red", "blue"])].copy()
match_df = match_df.rename(columns={"key": "match_key"})

# Load OPR and EPA data
def load_and_process_data(csv_path, phase):
    df = pd.read_csv(csv_path, low_memory=False)
    df = df[df["phase"].eq(phase)].copy() if "phase" in df.columns else df.copy()
    return df

opr_before_df = load_and_process_data(OPR_CSV, "before")
opr_after_df = load_and_process_data(OPR_CSV, "after")
epa_before_df = load_and_process_data(EPA_CSV, "before")
epa_after_df = load_and_process_data(EPA_CSV, "after")

# Process score breakdown to extract RP information
def process_score_breakdown(score_breakdown):
    if pd.isna(score_breakdown):
        return {
            "match_result": 0,
            "rps": 0,
            "rp1": 0,
            "rp2": 0,
            "rp3": 0,
        }

    try:
        breakdown = eval(score_breakdown)
    except:
        return {
            "match_result": 0,
            "rps": 0,
            "rp1": 0,
            "rp2": 0,
            "rp3": 0,
        }

    result = {
        "match_result": 1 if breakdown.get("win", False) else 0,
        "rps": breakdown.get("rp", 0),
        "rp1": 1 if breakdown.get("rp1", False) else 0,
        "rp2": 1 if breakdown.get("rp2", False) else 0,
        "rp3": 1 if breakdown.get("rp3", False) else 0,
    }
    return result

# Process match data to extract team information
def process_alliances(alliances):
    if pd.isna(alliances):
        return {"red_teams": [], "blue_teams": []}

    try:
        alliances_data = eval(alliances)
    except:
        return {"red_teams": [], "blue_teams": []}

    return {
        "red_teams": alliances_data.get("red", {}).get("team_keys", []),
        "blue_teams": alliances_data.get("blue", {}).get("team_keys", []),
    }

# Apply processing functions
match_df["score_info"] = match_df["score_breakdown"].apply(process_score_breakdown)
match_df["alliance_info"] = match_df["alliances"].apply(process_alliances)

# Create a lookup dictionary for match results
match_results = {
    row["match_key"]: {
        "winning_alliance": row["winning_alliance"],
        "red_teams": row["alliance_info"]["red_teams"],
        "blue_teams": row["alliance_info"]["blue_teams"],
        "red_result": row["score_info"]["match_result"] if row["winning_alliance"] == "red" else 0,
        "blue_result": row["score_info"]["match_result"] if row["winning_alliance"] == "blue" else 0,
        "red_rps": row["score_info"]["rps"] if row["winning_alliance"] == "red" else 0,
        "blue_rps": row["score_info"]["rps"] if row["winning_alliance"] == "blue" else 0,
        "red_rp1": row["score_info"]["rp1"] if row["winning_alliance"] == "red" else 0,
        "blue_rp1": row["score_info"]["rp1"] if row["winning_alliance"] == "blue" else 0,
        "red_rp2": row["score_info"]["rp2"] if row["winning_alliance"] == "red" else 0,
        "blue_rp2": row["score_info"]["rp2"] if row["winning_alliance"] == "blue" else 0,
        "red_rp3": row["score_info"]["rp3"] if row["winning_alliance"] == "red" else 0,
        "blue_rp3": row["score_info"]["rp3"] if row["winning_alliance"] == "blue" else 0,
    }
    for _, row in match_df.iterrows()
}

# Function to merge OPR and EPA data with match results
def merge_data(opr_df, epa_df, phase):
    # Merge OPR and EPA data
    merged_df = pd.merge(opr_df, epa_df, on=["match_key", "alliance", "team_key"], suffixes=("_opr", "_epa"))

    # Add match results information
    rows = []
    for _, row in merged_df.iterrows():
        match_key = row["match_key"]
        if match_key not in match_results:
            continue

        match_info = match_results[match_key]
        is_red = row["alliance"] == "red"

        new_row = row.to_dict()
        new_row.update({
            "match_result": match_info[f"{row['alliance']}_result"],
            "rps": match_info[f"{row['alliance']}_rps"],
            "rp1": match_info[f"{row['alliance']}_rp1"],
            "rp2": match_info[f"{row['alliance']}_rp2"],
            "rp3": match_info[f"{row['alliance']}_rp3"],
            "phase": phase,
        })
        rows.append(new_row)

    return pd.DataFrame(rows)

# Create the final datasets
before_df = merge_data(opr_before_df, epa_before_df, "before")
after_df = merge_data(opr_after_df, epa_after_df, "after")

# Save the results
before_df.to_csv(OUTPUT_BEFORE, index=False)
after_df.to_csv(OUTPUT_AFTER, index=False)

print(f"Saved before-match data to {OUTPUT_BEFORE}")
print(f"Saved after-match data to {OUTPUT_AFTER}")
```